{
  "globalHeaders": {
    "Cache-Control": "no-cache"
  },
  "routes": [
    {
      "route": "/images/opt/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/images/*",
      "headers": {
        "Cache-Control": "public, max-age=2592000"
      }
    },
    {
      "route": "/*.css",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/*.js",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/book-online",
      "rewrite": "/book-online.html"
    },
    {
      "route": "/contact-us",
      "rewrite": "/contact-us.html"
    },
    {
      "route": "/services",
      "rewrite": "/services.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*", "/*.{css,js,png,jpg,jpeg,svg,pdf,xml,ico}"]
  }
}
